{
  "name": "page-builder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "copy-lib": "node -e \"const fs=require('fs'); if(fs.existsSync('../library')){fs.cpSync('../library','./public/library',{recursive:true});console.log('Library synced')}else{console.log('Using existing public/library')}\"",
    "dev": "npm run copy-lib && next dev",
    "build": "npm run copy-lib && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cheerio": "^1.2.0",
    "mammoth": "^1.12.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
